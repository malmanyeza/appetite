{
  "expo": {
    "name": "Appetite",
    "slug": "appetite-mobile",
    "owner": "solidifiedmal",
    "scheme": "appetite",
    "version": "1.7.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/transparent.png",
      "backgroundColor": "#FF4D00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appetite.mobile",
      "buildNumber": "32",
      "config": {
        "googleMapsApiKey": "AIzaSyAfW8js09sB0cfQzz19aRBkSE7sDMy5cu0"
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.707903087617-v1qf87j440t8gll84lgh3uf7dujrlqv8"
            ]
          }
        ],
        "NSCameraUsageDescription": "Allow Appetite to access your camera to take a photo for your driver profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow Appetite to access your photos to upload a driver profile picture.",
        "NSLocationWhenInUseUsageDescription": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4D00"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "malmanyeza.github.io",
              "pathPrefix": "/appetite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.appetite.delivery",
      "versionCode": 32,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAfW8js09sB0cfQzz19aRBkSE7sDMy5cu0"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.707903087617-v1qf87j440t8gll84lgh3uf7dujrlqv8"
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF4D00"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "appetite-oe",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "2b78d579-3b9d-4e47-95fe-9e230c7b016a"
      }
    }
  }
}
