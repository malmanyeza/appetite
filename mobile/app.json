{
  "expo": {
    "name": "Appetite",
    "slug": "appetite-mobile",
    "scheme": "appetite",
    "version": "1.2.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/transparent.png",
      "backgroundColor": "#FF4D00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appetite.mobile",
      "config": {
        "googleMapsApiKey": ""
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Appetite to access your camera to take a photo for your driver profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow Appetite to access your photos to upload a driver profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4D00"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "malmanyeza.github.io",
              "pathPrefix": "/appetite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.appetite.mobile",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF4D00",
          "sounds": ["./assets/sounds/appetite_alert.wav"]
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "appetite-oe",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ec762e78-887d-459c-93d5-1a82a4e2ee31"
      }
    }
  }
}