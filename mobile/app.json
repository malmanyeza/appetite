{
  "expo": {
    "name": "Appetite",
    "slug": "appetite-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appetite.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Appetite to access your camera to take a photo for your driver profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow Appetite to access your photos to upload a driver profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7ebdc389-a028-408c-a07d-25c357aaf65b"
      }
    },
    "owner": "malverneas"
  }
}