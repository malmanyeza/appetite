{
  "expo": {
    "name": "Appetite",
    "slug": "appetite-mobile",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appetite.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Appetite to access your camera to take a photo for your driver profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow Appetite to access your photos to upload a driver profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.appetite.mobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF4D00"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "appetite-oe",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f9d5d1d3-6f24-44cc-92c1-9269f6e7c69e"
      }
    }
  }
}
