{
  "expo": {
    "name": "Appetite",
    "slug": "appetite-mobile",
    "scheme": "appetite",
    "version": "1.3.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/transparent.png",
      "backgroundColor": "#FF4D00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appetite.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyAfW8js09sB0cfQzz19aRBkSE7sDMy5cu0"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Appetite to access your camera to take a photo for your driver profile picture.",
        "NSPhotoLibraryUsageDescription": "Allow Appetite to access your photos to upload a driver profile picture.",
        "NSLocationWhenInUseUsageDescription": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4D00"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "malmanyeza.github.io",
              "pathPrefix": "/appetite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.appetite.delivery",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAfW8js09sB0cfQzz19aRBkSE7sDMy5cu0"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Appetite to use your location to find nearby restaurants and dispatch deliveries accurately."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#FF4D00"
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://zmsactoninhdtngtlyep.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inptc2FjdG9uaW5oZHRuZ3RseWVwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3NTk2ODksImV4cCI6MjA5MTMzNTY4OX0.FDgdXuVaDJe_yM5S9UhVB-Y-PEcbBQOm5M-ndAeJMWQ",
      "eas": {
        "projectId": "009a559f-a604-47f4-b4c9-26bccb2604b2"
      }
    },
    "owner": "jueasbuilds"
  }
}